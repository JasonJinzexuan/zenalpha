# Project
project_name = "zenalpha"
environment  = "prod"
region       = "us-east-1"

# EKS
eks_node_instance_type = "t3.medium"
eks_node_count         = 3
eks_node_min           = 2
eks_node_max           = 5

# RDS
db_instance_class = "db.t3.medium"
db_name           = "zenalpha"
db_username       = "zenalpha_admin"
db_password       = "CHANGE_ME_USE_SECRETS_MANAGER"
db_multi_az       = false
db_storage_gb     = 20

# Domain (optional)
domain_name         = ""
acm_certificate_arn = ""
